            },
            "url": {
              "raw": "{{baseUrl}}/project-assignments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "project-assignments"
              ]
            },
            "description": "PROJECT_MANAGER only. Sends notifications to project participants."
          }
        },
        {
          "name": "Get Assigned Team Members",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('managerToken');",
                  "if (token) pm.collectionVariables.set('token', token);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
