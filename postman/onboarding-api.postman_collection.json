            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": {{projectId}},\n  \"title\": \"Collect onboarding details\",\n  \"description\": \"Ask customer for onboarding implementation details and confirm requirements.\",\n  \"priority\": \"MEDIUM\",\n  \"dueDate\": \"{{taskDueDate}}\",\n  \"assignee\": {{assigneeId}}\n}"
