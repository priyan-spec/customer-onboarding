{
  "info": {
    "_postman_id": "b8f9dd3b-7b0c-4e3d-bb81-8572e2b6aa49",
    "name": "Customer Onboarding Tracker API",
    "description": "Postman collection for the Customer Onboarding Tracker backend.\n\nUse this collection with the backend running at `{{baseUrl}}`.\n\nRecommended setup order:\n1. Run the three register requests once, or keep the default users if they already exist.\n2. Run Login Customer, Login Manager, and Login Team Member. These save `customerToken`, `managerToken`, `teamToken`, and user IDs.\n3. Create a project as customer.\n4. As manager, get team members, assign a team member, then create tasks.\n5. Use the Notifications folder to verify persisted notifications. The API returns at most 3 notifications.\n\nMost protected requests automatically switch `{{token}}` to the role-specific token in their pre-request script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('No server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
