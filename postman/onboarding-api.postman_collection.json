        {
          "name": "Get Tasks By Project",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('managerToken') || pm.collectionVariables.get('customerToken');",
