      "name": "02 - Users and Assignments",
      "item": [
        {
          "name": "Get Team Members",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('managerToken');",
                  "if (token) pm.collectionVariables.set('token', token);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Team members returned', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const loggedInTeamMemberId = Number(pm.collectionVariables.get('teamMemberId'));",
                  "const loggedInTeamMemberEmail = pm.collectionVariables.get('teamMemberEmail');",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  const matchingMember = json.find((member) => Number(member.id) === loggedInTeamMemberId) || json.find((member) => member.email === loggedInTeamMemberEmail) || json[0];",
                  "  pm.collectionVariables.set('assigneeId', matchingMember.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/team-members",
